# yanger environment variables
#
# Copy this file to one of:
#   ~/.config/yanger/.env   (applies everywhere)
#   ./.env                  (project-local)
# Variables already exported in your shell take precedence over these files.

# YouTube Data API key (optional; OAuth is used for mutating operations).
# YOUTUBE_API_KEY=""

# Override the cache directory.
# YANGER_CACHE_DIR="~/.cache/yanger"

# Command run by `:transcript` against the currently selected video.
# {url} -> https://www.youtube.com/watch?v=<id>   {id} -> the raw video id
# If neither placeholder appears, the video URL is appended automatically.
# The command runs through your shell, so pipes work. Pick one:
#
#   YANGER_TRANSCRIPT_COMMAND="summarize {url}"
#   YANGER_TRANSCRIPT_COMMAND="yeet {url}"
#   YANGER_TRANSCRIPT_COMMAND="yt-dlp --write-auto-subs --skip-download --sub-langs en {url}"
#   YANGER_TRANSCRIPT_COMMAND="yeet {url} | fabric -sp summarize"   # transcript -> LLM
#
# YANGER_TRANSCRIPT_COMMAND=""

# Transcript proxy (YouTube blocks transcript requests from many cloud/datacenter IPs).
# Setting a generic proxy URL, OR both Webshare credentials, auto-enables the proxy.
# See `yanger proxy status` / `yanger proxy test`.
#
# Generic HTTP(S) proxy:
#   YANGER_PROXY_HTTPS="https://user:pass@host:port"   # YANGER_PROXY_URL is an alias
#   YANGER_PROXY_HTTP="http://user:pass@host:port"
#
# Webshare — use ROTATING RESIDENTIAL proxies (datacenter Webshare is itself blocked):
#   YANGER_WEBSHARE_USER=""
#   YANGER_WEBSHARE_PASS=""
